<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_food_product_list" model="ir.ui.view">
        <field name="name">food.product.list</field>
        <field name="model">food.product</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="category"/>
                <field name="price"/>
                <field name="prep_time"/>
                <field name="rating"/>
                <field name="tag"/>
                <field name="is_available"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_food_product_form" model="ir.ui.view">
        <field name="name">food.product.form</field>
        <field name="model">food.product</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="category"/>
                            <field name="price"/>
                            <field name="prep_time"/>
                        </group>
                        <group>
                            <field name="rating"/>
                            <field name="tag"/>
                            <field name="emoji"/>
                            <field name="is_available"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="description" placeholder="Describe el producto para el catalogo"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_food_products" model="ir.actions.act_window">
        <field name="name">Productos</field>
        <field name="res_model">food.product</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_food_products"
        name="Productos"
        parent="menu_food_orders_root"
        action="action_food_products"
        sequence="5"
    />

